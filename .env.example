# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/demo_vibe"

# Backend
PORT=4000
FRONTEND_URL=http://localhost:3000

# JWT (legacy — Firebase Auth is primary)
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRATION=900
JWT_REFRESH_EXPIRATION=259200

# Social Auth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── Email Provider ──────────────────────────────────────
# MAIL_PROVIDER: "ses" | "smtp" (auto-detects if omitted)
#   - If AWS_SES_SMTP_USER is set → auto-selects "ses"
#   - Otherwise → falls back to "smtp"
MAIL_PROVIDER=

# Common
MAIL_FROM="Vibe <noreply@yourdomain.com>"

# Option A: AWS SES (recommended for production)
#   1. Create SMTP credentials in AWS SES console
#   2. Verify sender email/domain in SES
#   3. Fill in the values below
AWS_SES_REGION=ap-northeast-2
AWS_SES_SMTP_USER=
AWS_SES_SMTP_PASSWORD=

# Option B: SMTP (Google App Password / Mailtrap / etc.)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:4000
